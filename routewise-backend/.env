NEON_AUTH_URL=https://ep-broad-sound-adhqszld.neonauth.c-2.us-east-1.aws.neon.tech/neondb/auth
JWT_ISSUER=https://ep-broad-sound-adhqszld.neonauth.c-2.us-east-1.aws.neon.tech/neondb/auth
# The audience is usually the project ID or a specific client ID if you have one.
# For Neon Auth, the issuer and audience might be the same or similar depending on setup.
JWT_AUDIENCE=neondb_auth_audience

# Email config (Gmail SMTP) — required for password reset emails
# Use a Gmail App Password, NOT your regular password:
# Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password_here

# Frontend base URL (for reset link in email)
FRONTEND_URL=http://localhost:5173